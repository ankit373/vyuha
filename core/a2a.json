{
    "project": "VYUHA",
    "version": "2.1.0",
    "protocol": "A2A",
    "governance_defaults": {
        "mode": "CONSENSUS",
        "timeout": 30
    },
    "flows": {
        "software_build": [
            {
                "topic": "requirements/input",
                "start_node": "Sutra"
            },
            {
                "topic": "requirements/draft",
                "next_node": "Sutradhara",
                "is_action": true
            },
            {
                "topic": "architecture/input",
                "next_node": "Vishwakarma"
            },
            {
                "topic": "code/generate",
                "next_node": "Yantra",
                "is_action": true
            },
            {
                "topic": "verification/run",
                "next_node": "Pariksha"
            }
        ],
        "bug_fix": [
            {
                "topic": "bug/report",
                "start_node": "Pariksha"
            },
            {
                "topic": "debug/request",
                "next_node": "Yantra",
                "is_action": true
            },
            {
                "topic": "fix/verify",
                "next_node": "Pariksha"
            }
        ],
        "documentation_update": [
            {
                "topic": "docs/request",
                "start_node": "Lipi"
            },
            {
                "topic": "docs/draft",
                "next_node": "Sutradhara",
                "is_action": true
            }
        ],
        "data_pipeline_build": [
            {
                "topic": "data/requirements",
                "start_node": "Ganaka"
            },
            {
                "topic": "pipeline/draft",
                "next_node": "Varuna",
                "is_action": true
            },
            {
                "topic": "ml/train",
                "next_node": "Budhi",
                "is_action": true
            },
            {
                "topic": "ml/deploy",
                "next_node": "Yantri",
                "is_action": true
            }
        ]
    },
    "formation": {
        "Core Dev Suite": {
            "Sutra": {
                "role": "Lead Requirements Engineer",
                "reviewers": [
                    "Sutradhara"
                ],
                "review_mode": "CONSENSUS"
            },
            "Dharma": {
                "role": "Principal Standards Architect",
